{
  "name": "viet-chatter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "WhatsApp bot autonomo a risposta filtrata, timing umano-simile, memoria per persona.",
  "scripts": {
    "start": "tsx src/index.ts",
    "start:test": "node scripts/start-test.mjs bot",
    "dev": "concurrently -k -n bot,web -c blue,green --kill-signal SIGINT \"tsx src/index.ts\" \"node scripts/free-port.mjs 3000 && next dev ./web -p 3000 --hostname 127.0.0.1\"",
    "dev:test": "node scripts/start-test.mjs dev",
    "dev:bot": "tsx src/index.ts",
    "dev:web": "node scripts/free-port.mjs 3000 && next dev ./web -p 3000 --hostname 127.0.0.1",
    "build": "tsc -p tsconfig.json",
    "build:web": "next build ./web",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "health": "tsx src/scripts/health.ts",
    "test": "npm run test:unit",
    "test:unit": "node scripts/test-unit.mjs",
    "test:e2e": "tsx src/scripts/test-e2e.ts",
    "test:e2e:full": "tsx e2e/run.ts",
    "loc": "node scripts/cloc.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^11.5.0",
    "chokidar": "^4.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.36.4",
    "lucide-react": "^0.474.0",
    "next": "^15.5.18",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "pino-roll": "^2.0.0",
    "qrcode-terminal": "^0.12.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hook-form": "^7.54.2",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sqlite-vec": "^0.1.6",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "whatsapp-web.js": "^1.34.7",
    "yaml": "^2.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.5",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "drizzle-kit": "^0.27.2",
    "eslint": "^9",
    "eslint-config-next": "^15.5.18",
    "postcss": "^8.5.1",
    "prettier": "^3.7.4",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
