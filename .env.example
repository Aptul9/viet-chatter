# viet-chatter env vars
# Copy to .env and fill in. .env is gitignored.

# Telegram escalation channel (optional). Lascia vuoto per disabilitare.
TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_CHAT_ID=

# OpenCode overrides (vedi docs/dev/07-ai-integration.md). Lascia vuoto per default.
OPENCODE_DISABLE_AUTOUPDATE=1
OPENCODE_DISABLE_LSP=1
